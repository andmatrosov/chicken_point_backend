APP_NAME="Mobile Game Backend"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC
FRONTEND_URLS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Recommended local setup: MySQL 8+ or PostgreSQL + Redis.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=mobile_game
DB_USERNAME=root
DB_PASSWORD=

# PostgreSQL example:
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=mobile_game
# DB_USERNAME=postgres
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

GAME_LEADERBOARD_SIZE=15
GAME_SESSION_TTL_SECONDS=900
GAME_SESSION_TOKEN_LENGTH=64
GAME_INVALIDATE_PREVIOUS_ACTIVE_SESSIONS=false
# Optional per-user active session limit. Leave empty to disable.
GAME_MAX_ACTIVE_SESSIONS_PER_USER=
GAME_PASSWORD_MIN_LENGTH=8
GAME_AUTO_ACTIVATE_FIRST_SKIN=true
GAME_PRIZE_USE_REMAINING_STOCK=true
GAME_MIN_SCORE=0
GAME_MAX_SCORE=1000000
GAME_MAX_COINS_COLLECTED_PER_RUN=1000
GAME_MIN_DURATION_SECONDS=5
GAME_MAX_DURATION_SECONDS=7200
GAME_RATE_LIMIT_LOGIN_PER_MINUTE=5
GAME_RATE_LIMIT_REGISTER_PER_MINUTE=3
GAME_RATE_LIMIT_PROFILE_PER_MINUTE=60
GAME_RATE_LIMIT_ACTIVE_SKIN_PER_MINUTE=20
GAME_RATE_LIMIT_SESSION_START_PER_MINUTE=30
GAME_RATE_LIMIT_SUBMIT_SCORE_PER_MINUTE=20
GAME_RATE_LIMIT_BUY_SKIN_PER_MINUTE=10

# Bearer token lifetime in minutes. Set to 0 or a negative value to disable expiry.
SANCTUM_TOKEN_EXPIRATION_MINUTES=43200
# Current API auth is bearer-token based. FRONTEND_URLS controls browser CORS origins.
# SANCTUM_STATEFUL_DOMAINS is only relevant if the project later enables Sanctum SPA cookie auth.

# Local fallback is storage/app/geoip/GeoLite2-Country.mmdb.
# Production should use an external mounted file, for example:
GEOIP_COUNTRY_DATABASE_PATH=/data/geoip/GeoLite2-Country.mmdb

L5_SWAGGER_ENABLED=false
L5_SWAGGER_GENERATE_ALWAYS=false

VITE_APP_NAME="${APP_NAME}"
